{
  "expo": {
    "name": "Netra Astra",
    "slug": "netra-astra",
    "scheme": "netraastra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.netraastra.app"
    },
    "android": {
      "package": "com.netraastra.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos so you can attach site-visit images to inquiry reports.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera so you can capture site-visit photos for inquiry reports."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/NetrAstra"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "474d1a24-d028-4d62-80eb-d6b9df32afae"
      }
    },
    "owner": "devpatel99"
  }
}
